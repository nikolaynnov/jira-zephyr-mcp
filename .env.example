# JIRA 8.12 Server + Zephyr for JIRA 5.6.3 (Zephyr Squad).
# ZAPI runs on the same JIRA host, so no separate Zephyr token is needed.

JIRA_BASE_URL=https://jira.your-company.com

# --- Authentication: pick ONE mode ---
# Mode A (any JIRA version, incl. < 8.14): Basic auth with login + password.
JIRA_USERNAME=your-jira-login
JIRA_PASSWORD=your-jira-password
# Mode B (JIRA 8.14+): Personal Access Token (Bearer). Takes precedence over
# JIRA_USERNAME/JIRA_PASSWORD when set, so you can switch by dropping it in.
# JIRA_API_TOKEN=your-personal-access-token

# Name of the "Test" issue type. Often localized (e.g. Тест). Optional:
# auto-detected from the instance when omitted.
# JIRA_TEST_ISSUE_TYPE=Test

# --- Optional HTTP behavior ---
# Route through the corporate proxy (HTTP(S)_PROXY). Off by default: internal
# JIRA hosts are reached directly. Set to 1 to opt back in.
# JIRA_USE_PROXY=0
# Disable TLS certificate verification (self-signed internal certs). Use with care.
# JIRA_INSECURE_TLS=0
# Override the User-Agent sent to JIRA.
# JIRA_USER_AGENT=