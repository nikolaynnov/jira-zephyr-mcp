# API compatibility probe (npm run check-api)
# Target: JIRA 8.12 Server + Zephyr for JIRA 5.6.3 (ZAPI)
# Copy the values you need into .env before running the probe.

# --- Required: target server + Basic auth (login / password) ---
JIRA_BASE_URL=https://jira.company.com
JIRA_USERNAME=your-login
JIRA_PASSWORD=your-password

# --- Optional probe fixtures (defaults shown; override for your project) ---
# Any issue is fine for the plain issue-read check.
PROBE_ISSUE_KEY=IPLUS-46358
# For full Zephyr coverage, point this at a project that actually has test cycles.
PROBE_PROJECT_KEY=QA
# PROBE_PROJECT_ID is auto-resolved from PROBE_PROJECT_KEY; set to override.
#PROBE_PROJECT_ID=10660
# The "Test" issue type is auto-detected (localized names like "Тест" are handled);
# set this to force a specific name.
#PROBE_TEST_ISSUETYPE=Тест

# --- Networking ---
# JIRA is an internal host, so the probe connects DIRECTLY and ignores the corporate
# HTTP(S)_PROXY (Squid) by default. Set to 1 to route through the proxy instead.
#PROBE_USE_PROXY=0
# Set to 1 if the server uses a self-signed / internal TLS certificate.
#PROBE_INSECURE_TLS=0
